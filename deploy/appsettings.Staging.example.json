{
  "AllowedHosts": "staging.example.com",
  "ConnectionStrings": {
    "Database": "Host=postgres.example.com;Port=5432;Database=carbon_footprint_staging;Username=from-secret-manager;Password=from-secret-manager;SSL Mode=VerifyFull"
  },
  "DataProtection": {
    "KeyPath": "/keys"
  },
  "Security": {
    "RequireHttpsCookies": true
  },
  "Mail": {
    "Host": "smtp.example.com",
    "Port": 587,
    "FromAddress": "no-reply-staging@example.com",
    "FromName": "產品碳足跡系統（測試）"
  },
  "ObjectStorage": {
    "Endpoint": "https://objects-staging.example.com",
    "Bucket": "carbon-evidence-staging",
    "AccessKey": "from-secret-manager",
    "SecretKey": "from-secret-manager"
  },
  "MalwareScanner": {
    "Host": "clamav",
    "Port": 3310
  }
}
