@page
@model CarbonFootprint.Web.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = Model.CreatesAdministrator ? "建立初始管理者" : "建立帳號";
    ViewData["BodyClass"] = "auth-page";
}

<section class="auth-shell auth-shell--setup" aria-labelledby="setup-title">
    <div class="auth-visual">
        <div class="auth-visual__content">
            <span class="eyebrow eyebrow-light">ACCOUNT SETUP</span>
            <h1>建立碳盤查<br />使用者帳號</h1>
            <p>完成 Email 確認後即可登入；系統會依角色顯示可使用的盤查、計算與管理功能。</p>
            <div class="setup-cycle" aria-hidden="true">
                <span>原料</span><span>製造</span><span>運輸</span><span>使用</span><span>回收</span>
            </div>
        </div>
    </div>

    <div class="auth-panel">
        <div class="auth-card">
            @if (Model.CreatesAdministrator)
            {
                <span class="eyebrow">首次設定</span>
                <h2 id="setup-title">建立初始管理者</h2>
                <p class="auth-card__intro">目前尚無已確認的系統管理者，此帳號完成 Email 確認後會取得管理者角色。</p>
            }
            else
            {
                <span class="eyebrow">帳號註冊</span>
                <h2 id="setup-title">建立新帳號</h2>
                <p class="auth-card__intro">新帳號預設為檢視者，完成 Email 確認後即可登入。</p>
            }

            <form method="post" class="auth-form" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                <div class="field-group">
                    <label asp-for="Input.DisplayName"></label>
                    <div class="field-control">
                        <span class="field-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 21c1-5 4-7 8-7s7 2 8 7" /></svg>
                        </span>
                        <input asp-for="Input.DisplayName" autocomplete="name" placeholder="例如：碳盤查管理員" />
                    </div>
                    <span asp-validation-for="Input.DisplayName" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Input.Email"></label>
                    <div class="field-control">
                        <span class="field-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M4 5h16v14H4zM4 7l8 6 8-6" /></svg>
                        </span>
                        <input asp-for="Input.Email" autocomplete="email" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label asp-for="Input.Password"></label>
                        <div class="field-control">
                            <input asp-for="Input.Password" autocomplete="new-password" placeholder="至少 6 個字元" />
                        </div>
                        <span asp-validation-for="Input.Password" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label asp-for="Input.ConfirmPassword"></label>
                        <div class="field-control">
                            <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="再次輸入密碼" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-carbon btn-carbon--wide">
                    建立帳號並寄送確認信
                    <span aria-hidden="true">→</span>
                </button>
            </form>

            <div class="auth-account-links auth-account-links--single">
                <a class="initial-account-link" href="/Identity/Account/ResendEmailConfirmation">已註冊但沒收到信？重寄確認信</a>
            </div>
            <a class="auth-back" href="/Identity/Account/Login" data-history-back>← 返回上一頁</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
