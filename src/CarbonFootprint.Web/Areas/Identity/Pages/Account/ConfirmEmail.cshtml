@page
@model CarbonFootprint.Web.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Email 確認";
    ViewData["BodyClass"] = "auth-page";
}

<section class="auth-shell auth-shell--setup" aria-labelledby="confirm-title">
    <div class="auth-visual">
        <div class="auth-visual__content">
            <span class="eyebrow eyebrow-light">EMAIL CONFIRMATION</span>
            <h1>確認帳號<br />開始碳盤查</h1>
            <p>完成 Email 確認後，即可依帳號角色使用產品碳足跡盤查與計算功能。</p>
        </div>
    </div>

    <div class="auth-panel">
        <div class="auth-card">
            @if (Model.Succeeded)
            {
                <span class="eyebrow">確認完成</span>
                <h2 id="confirm-title">Email 已確認</h2>
                <p class="auth-card__intro">帳號已啟用，現在可以登入碳足跡系統。</p>
                <a class="btn-carbon btn-carbon--wide" asp-page="./Login">前往登入 <span aria-hidden="true">→</span></a>
            }
            else
            {
                <span class="eyebrow">確認失敗</span>
                <h2 id="confirm-title">確認連結無效</h2>
                <p class="auth-card__intro">連結可能已使用、過期或不完整，請重新寄送確認信。</p>
                <a class="btn-carbon btn-carbon--wide" asp-page="./ResendEmailConfirmation">重新寄送確認信 <span aria-hidden="true">→</span></a>
            }
        </div>
    </div>
</section>
