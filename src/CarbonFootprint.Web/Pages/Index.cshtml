@page
@model IndexModel
@{
    ViewData["Title"] = "首頁";
}

<div class="py-5">
    <h1 class="display-5">可重現的產品碳足跡盤查</h1>
    <p class="lead">保存活動數據、單位換算、係數版本、輸入快照與逐項計算結果，讓每次 calculation run 都可追溯。</p>
    <p>
        <a class="btn btn-primary" asp-page="/Workspace">進入盤查工作區</a>
    </p>
    <div class="alert alert-warning mt-4" role="note">
        系統協助盤查、計算與查驗準備；不會自行宣稱結果已通過 ISO 認證、第三方查驗或取得碳標籤。
    </div>
</div>
