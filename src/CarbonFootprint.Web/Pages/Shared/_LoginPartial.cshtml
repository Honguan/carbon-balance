@using CarbonFootprint.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<div class="account-nav">
@if (SignInManager.IsSignedIn(User))
{
    var roleLabel = User.IsInRole(SystemRoles.Administrator) ? "系統管理者"
        : User.IsInRole(SystemRoles.Manager) ? "盤查主管"
        : User.IsInRole(SystemRoles.Editor) ? "盤查編輯者"
        : User.IsInRole(SystemRoles.Viewer) ? "檢視者"
        : "一般使用者";
    var accountName = string.IsNullOrWhiteSpace(User.Identity?.Name) ? "使用者" : User.Identity.Name;
    var accountInitial = accountName![0].ToString().ToUpperInvariant();

    <div class="account-chip" title="目前登入角色">
        <span class="account-chip__avatar" aria-hidden="true">@accountInitial</span>
        <span class="account-chip__text">
            <strong>@accountName</strong>
            <small>@roleLabel</small>
        </span>
    </div>
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
        <button type="submit" class="nav-logout">登出</button>
    </form>
}
else
{
    <a class="nav-login" asp-area="Identity" asp-page="/Account/Login">登入系統</a>
}
</div>
