@page "{section?}"
@model CarbonFootprint.Web.Pages.WorkspaceModel
@using CarbonFootprint.Domain.Modules.Factors
@using CarbonFootprint.Domain.Modules.Inventories
@using CarbonFootprint.Domain.Modules.Standards
@{
    ViewData["Title"] = "盤查工作區";
    var isSetupSection = Model.Section is "setup" or "product" or "pcr" or "inventory";
    var latestSelectedRun = Model.Runs.FirstOrDefault(item => item.ProjectVersionId == Model.ProjectVersionId);
    var hasFacilities = Model.Facilities.Count > 0;
    var hasProductVersions = Model.ProductVersions.Count > 0;
    var hasSelectablePcrVersions = Model.SelectablePcrVersions.Count > 0;
    var hasSelectableFactors = Model.SelectableFactors.Count > 0;
    var canCreateInventory = hasProductVersions && hasSelectablePcrVersions;
    var lifecycleSections = new[]
    {
        new { Stage = LifecycleStage.RawMaterial, Number = "01", Slug = "raw-material", Title = "原料取得", Summary = "原物料投入與供應商運輸", ActivityLabel = "原物料名稱／運輸項目", ScenarioLabel = "材質／供應商名稱與地址", ValueLabel = "投入量／運輸量", Kinds = new[] { ActivityDataKind.Material, ActivityDataKind.MaterialTransport } },
        new { Stage = LifecycleStage.Manufacturing, Number = "02", Slug = "manufacturing", Title = "製造", Summary = "能資源、製造廢棄與委外運輸", ActivityLabel = "能資源／廢棄物名稱", ScenarioLabel = "製程／處理廠與運輸說明", ValueLabel = "使用量／廢棄量／運輸量", Kinds = new[] { ActivityDataKind.Energy, ActivityDataKind.ManufacturingWaste, ActivityDataKind.OutsourcedTreatmentTransport } },
        new { Stage = LifecycleStage.Distribution, Number = "03", Slug = "distribution", Title = "配送銷售", Summary = "配銷據點與銷售運輸", ActivityLabel = "配銷據點／運輸項目", ScenarioLabel = "據點地址／運輸工具", ValueLabel = "重量距離活動量", Kinds = new[] { ActivityDataKind.DistributionTransport } },
        new { Stage = LifecycleStage.Use, Number = "04", Slug = "use", Title = "使用", Summary = "使用壽命、頻率、能源與耗材", ActivityLabel = "使用情境名稱", ScenarioLabel = "壽命／頻率／能源或耗材說明", ValueLabel = "情境活動量", Kinds = new[] { ActivityDataKind.UseEnergy, ActivityDataKind.UseConsumable } },
        new { Stage = LifecycleStage.EndOfLife, Number = "05", Slug = "end-of-life", Title = "廢棄處理", Summary = "回收、焚化、掩埋與處理運輸", ActivityLabel = "處理方式／運輸項目", ScenarioLabel = "處理廠／服務與運輸情境", ValueLabel = "廢棄量／運輸量", Kinds = new[] { ActivityDataKind.EndOfLifeTreatment, ActivityDataKind.EndOfLifeTransport } }
    };
}
<header class="workspace-hero">
    <p class="workspace-eyebrow">產品碳足跡盤查流程</p>
    <h1>盤查工作區</h1>
    <p>依序完成組織與產品資料、盤查邊界、係數、五階段活動數據，再建立可重現的計算結果。</p>
    <p class="workspace-disclaimer">Golden Vertical Slice：所有資料均為開發測試資料，不代表 PCR、係數或結果已獲領域核准、查驗或主管機關核定。</p>
</header>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status">@Model.StatusMessage</div>
}
<div asp-validation-summary="All" class="text-danger" role="alert"></div>

@if (!Model.OrganizationId.HasValue)
{
    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h4">1. 建立組織</h2>
            <form method="post" asp-page-handler="CreateOrganization">
                <label class="form-label" for="organizationName">組織名稱</label>
                <input class="form-control" id="organizationName" name="organizationName" required maxlength="200" />
                <button class="btn btn-primary mt-3" type="submit">建立組織</button>
            </form>
        </div>
    </section>
}
else
{
    <div class="workspace-context">
        <span>目前組織</span>
        <code>@Model.OrganizationId</code>
    </div>

    <nav class="workspace-stage-nav" aria-label="盤查作業分頁">
        <a asp-page="/Workspace" asp-route-section="governance" aria-current="@(Model.Section == "governance" ? "page" : null)"><span>01</span>組織與廠場</a>
        <div class="workspace-stage-group" aria-current="@(isSetupSection ? "page" : null)">
            <a asp-page="/Workspace" asp-route-section="product" aria-current="@(Model.Section == "product" ? "page" : null)"><span>02</span>產品基本資料</a>
            <a asp-page="/Workspace" asp-route-section="pcr" aria-current="@(Model.Section == "pcr" ? "page" : null)"><span>03</span>PCR 規範</a>
            <a asp-page="/Workspace" asp-route-section="inventory" aria-current="@(Model.Section == "inventory" ? "page" : null)"><span>04</span>盤查範圍</a>
        </div>
        <a asp-page="/Workspace" asp-route-section="factors" aria-current="@(Model.Section == "factors" ? "page" : null)"><span>05</span>排放係數</a>
        <a asp-page="/Workspace" asp-route-section="lifecycle" aria-current="@(Model.Section == "lifecycle" ? "page" : null)"><span>06</span>五階段數據</a>
        <a asp-page="/Workspace" asp-route-section="calculation" aria-current="@(Model.Section == "calculation" ? "page" : null)"><span>07</span>計算與結果</a>
    </nav>

    @if (Model.Section == "governance")
    {
    <section class="card mb-4 workspace-card" id="governance">
        <div class="card-body">
            <div class="workspace-card-heading">
                <span class="workspace-step">01</span>
                <div>
                    <h2 class="h4">組織、成員與廠場</h2>
                    <p>先確認盤查資料的歸屬組織、作業廠場與協作權限。</p>
                </div>
            </div>
            <div class="row g-3">
                <form class="col-lg-4 workspace-subpanel" method="post" asp-page-handler="CreateFacility">
                    <h3 class="h6">廠場基本資料</h3>
                    <label class="form-label" for="facilityCode">廠場代碼</label>
                    <input class="form-control" id="facilityCode" name="facilityCode" required maxlength="100" />
                    <label class="form-label mt-2" for="facilityName">廠場名稱</label>
                    <input class="form-control" id="facilityName" name="facilityName" required maxlength="300" />
                    <button class="btn btn-primary mt-2" type="submit">建立廠場</button>
                </form>
                <form class="col-lg-4 workspace-subpanel" method="post" asp-page-handler="InviteMember">
                    <h3 class="h6">新增協作成員</h3>
                    <label class="form-label" for="invitationEmail">受邀 Email</label>
                    <input class="form-control" id="invitationEmail" name="invitationEmail" type="email" required maxlength="320" />
                    <label class="form-label mt-2" for="invitationRole">角色</label>
                    <select class="form-select" id="invitationRole" name="invitationRole">
                        @foreach (var role in Enum.GetValues<CarbonFootprint.Domain.Modules.Organizations.OrganizationRole>().Where(role => role != CarbonFootprint.Domain.Modules.Organizations.OrganizationRole.Owner))
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <button class="btn btn-primary mt-2" type="submit">寄送邀請</button>
                </form>
                <div class="col-lg-4 workspace-subpanel">
                    <h3 class="h6">現有成員與角色</h3>
                    <ul>
                        @foreach (var membership in Model.Memberships)
                        {
                            <li>
                                @membership.UserId：@membership.Role
                                @if (membership.RevokedAt is null && membership.Role != CarbonFootprint.Domain.Modules.Organizations.OrganizationRole.Owner.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="RevokeMember">
                                        <input type="hidden" name="membershipId" value="@membership.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">撤銷</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <h3 class="h6 mt-4">待處理邀請</h3>
            <ul>
                @foreach (var invitation in Model.Invitations.Where(item => item.AcceptedAt is null && item.RevokedAt is null))
                {
                    <li>
                        @invitation.Email：@invitation.Role（到期 @invitation.ExpiresAt.ToString("u")）
                        <form class="d-inline" method="post" asp-page-handler="RevokeInvitation">
                            <input type="hidden" name="invitationId" value="@invitation.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">撤銷邀請</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </section>
    }

    <div class="row g-4">
        @if (isSetupSection)
        {
        <div class="col-12">
            <section class="workspace-setup-shell" aria-labelledby="setup-heading">
                <div class="workspace-group-heading">
                    <span>02–04</span>
                    <div>
                        <h2 id="setup-heading">產品基本資料與盤查設定</h2>
                        <p>依序建立產品、保存 PCR 規範，再設定盤查範圍；三個區塊各自儲存。</p>
                    </div>
                </div>
                <div class="row g-4">
                @if (Model.Section is "setup" or "product")
                {
                <div class="col-12">
            <section class="card h-100 workspace-card" id="product">
                <div class="card-body">
                    <div class="workspace-card-heading">
                        <span class="workspace-step">02</span>
                        <div>
                            <h2 class="h4">產品基本資料</h2>
                            <p>建立盤查對象、分類與生產廠場的版本關係。</p>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="CreateProduct">
                        <h3 class="workspace-subheading">產品識別</h3>
                        <label class="form-label" for="productName">產品名稱</label>
                        <input class="form-control" id="productName" name="productName" required maxlength="300" />
                        <label class="form-label mt-2" for="categoryCode">產品分類代碼</label>
                        <input class="form-control" id="categoryCode" name="categoryCode" required maxlength="100" />
                        <div class="workspace-select-field">
                            <label class="form-label mt-2" for="facilityId">所屬廠場</label>
                            <select class="form-select" id="facilityId" name="facilityId" required disabled="@(!hasFacilities)" aria-describedby="facilityId-help">
                                <option value="">@(hasFacilities ? "請選擇所屬廠場" : "尚無可選廠場")</option>
                                @foreach (var facility in Model.Facilities)
                                {
                                    <option value="@facility.Id">@facility.Code - @facility.Name</option>
                                }
                            </select>
                            <p class="workspace-select-help" id="facilityId-help">
                                @if (hasFacilities)
                                {
                                    <span>選擇此產品實際生產或管理的廠場。</span>
                                }
                                else
                                {
                                    <span>目前沒有廠場。請先到 <a asp-page="/Workspace" asp-route-section="governance">組織與廠場</a> 建立廠場。</span>
                                }
                            </p>
                        </div>
                        <button class="btn btn-primary mt-3" type="submit" disabled="@(!hasFacilities)">儲存產品第 1 版</button>
                    </form>
                    <h3 class="workspace-subheading mt-4">已建立版本</h3>
                    <ul class="workspace-records">
                        @foreach (var item in Model.ProductVersions)
                        {
                            <li>@item.NameZhTw（v@(item.VersionNumber)）</li>
                        }
                    </ul>
                </div>
            </section>
        </div>
                }

                @if (Model.Section is "setup" or "pcr")
                {
        <div class="col-12">
            <section class="card h-100 workspace-card" id="pcr">
                <div class="card-body">
                    <div class="workspace-card-heading">
                        <span class="workspace-step">03</span>
                        <div>
                            <h2 class="h4">PCR 規範版本</h2>
                            <p>分別記錄規範識別、有效期間、適用範圍與原始文件完整性。</p>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="CreatePcr">
                        <h3 class="workspace-subheading">規範識別與有效期間</h3>
                        <label class="form-label" for="registrationNumber">登錄編號</label>
                        <input class="form-control" id="registrationNumber" name="registrationNumber" required />
                        <label class="form-label mt-2" for="pcrTitle">名稱</label>
                        <input class="form-control" id="pcrTitle" name="title" required />
                        <label class="form-label mt-2" for="pcrVersionNumber">版本</label>
                        <input class="form-control" type="number" min="1" id="pcrVersionNumber" name="versionNumber" value="1" required />
                        <label class="form-label mt-2" for="pcrValidFrom">有效起日</label>
                        <input class="form-control" type="date" id="pcrValidFrom" name="validFrom" value="2025-01-01" />
                        <label class="form-label mt-2" for="pcrValidTo">有效迄日</label>
                        <input class="form-control" type="date" id="pcrValidTo" name="validTo" value="2027-12-31" />
                        <h3 class="workspace-subheading mt-4">標準與適用範圍</h3>
                        <label class="form-label mt-2" for="sourceReference">來源參照</label>
                        <input class="form-control" id="sourceReference" name="sourceReference" placeholder="文件編號或受控來源 URI" required />
                        <label class="form-label mt-2" for="standardCode">標準代碼</label>
                        <input class="form-control" id="standardCode" name="standardCode" value="ISO 14067" required />
                        <label class="form-label mt-2" for="cccClassification">CCC 分類</label>
                        <input class="form-control" id="cccClassification" name="cccClassification" required />
                        <label class="form-label mt-2" for="pcrApplicability">適用性</label>
                        <textarea class="form-control" id="pcrApplicability" name="pcrApplicability" required></textarea>
                        <label class="form-label mt-2" for="ruleRequirements">規則要求模板</label>
                        <textarea class="form-control" id="ruleRequirements" name="ruleRequirements" required></textarea>
                        <h3 class="workspace-subheading mt-4">原始文件完整性</h3>
                        <label class="form-label mt-2" for="originalDocumentName">原始文件名稱</label>
                        <input class="form-control" id="originalDocumentName" name="originalDocumentName" required />
                        <label class="form-label mt-2" for="originalDocumentSha256">原始文件 SHA-256</label>
                        <input class="form-control" id="originalDocumentSha256" name="originalDocumentSha256" pattern="[0-9a-fA-F]{64}" required />
                        <button class="btn btn-primary mt-3" type="submit">儲存 PCR 草稿</button>
                    </form>
                    <h3 class="workspace-subheading mt-4">審查與發布狀態</h3>
                    <ul class="workspace-records">
                        @foreach (var pcr in Model.PcrVersions)
                        {
                            <li class="mb-2">
                                @pcr.RegistrationNumber v@(pcr.VersionNumber)：@pcr.Title（@pcr.PublicationStatus）
                                @if (pcr.PublicationStatus == PcrPublicationStatus.Draft.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="ReviewPcr">
                                        <input type="hidden" name="pcrVersionId" value="@pcr.Id" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit">核准審查</button>
                                    </form>
                                    <form class="d-inline" method="post" asp-page-handler="PublishPcr">
                                        <input type="hidden" name="pcrVersionId" value="@pcr.Id" />
                                        <button class="btn btn-sm btn-success" type="submit">發布</button>
                                    </form>
                                }
                                else if (pcr.PublicationStatus == PcrPublicationStatus.Published.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="WithdrawPcr">
                                        <input type="hidden" name="pcrVersionId" value="@pcr.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">撤回</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>
                }

                @if (Model.Section is "setup" or "inventory")
                {
        <div class="col-12">
            <section class="card h-100 workspace-card" id="inventory">
                <div class="card-body">
                    <div class="workspace-card-heading">
                        <span class="workspace-step">04</span>
                        <div>
                            <h2 class="h4">盤查範圍與專案版本</h2>
                            <p>界定盤查期間、計算單位、系統邊界與資料處理原則。</p>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="CreateInventory">
                        <h3 class="workspace-subheading">盤查對象與期間</h3>
                        <div class="workspace-select-field">
                            <label class="form-label" for="productVersionId">產品版本</label>
                            <select class="form-select" id="productVersionId" name="productVersionId" required disabled="@(!hasProductVersions)" aria-describedby="productVersionId-help">
                                <option value="">@(hasProductVersions ? "請選擇產品版本" : "尚無可選產品版本")</option>
                                @foreach (var item in Model.ProductVersions)
                                {
                                    <option value="@item.Id">@item.NameZhTw v@(item.VersionNumber)</option>
                                }
                            </select>
                            <p class="workspace-select-help" id="productVersionId-help">
                                @if (!hasProductVersions)
                                {
                                    <span>請先到 <a asp-page="/Workspace" asp-route-section="product">產品基本資料</a> 建立產品版本。</span>
                                }
                                else
                                {
                                    <span>選擇本次盤查對應的產品版本。</span>
                                }
                            </p>
                        </div>
                        <label class="form-label mt-2" for="periodStart">期間起日</label>
                        <input class="form-control" type="date" id="periodStart" name="periodStart" value="2026-01-01" required />
                        <label class="form-label mt-2" for="periodEnd">期間迄日</label>
                        <input class="form-control" type="date" id="periodEnd" name="periodEnd" value="2026-12-31" required />
                        <h3 class="workspace-subheading mt-4">單位與系統邊界</h3>
                        <label class="form-label mt-2" for="functionalUnit">功能單位</label>
                        <input class="form-control" id="functionalUnit" name="functionalUnit" value="1 個產品" required />
                        <label class="form-label mt-2" for="declaredUnit">標示單位</label>
                        <input class="form-control" id="declaredUnit" name="declaredUnit" value="1 件" required />
                        <label class="form-label mt-2" for="systemBoundary">系統邊界</label>
                        <textarea class="form-control" id="systemBoundary" name="systemBoundary" required maxlength="1000">搖籃到墳墓</textarea>
                        <h3 class="workspace-subheading mt-4">分配、排除與資料假設</h3>
                        <label class="form-label mt-2" for="allocationMethod">分配方法</label>
                        <input class="form-control" id="allocationMethod" name="allocationMethod" value="物理量分配" required maxlength="200" />
                        <label class="form-label mt-2" for="allocationReason">分配理由</label>
                        <textarea class="form-control" id="allocationReason" name="allocationReason" required maxlength="2000">依產品產量比例分配共同投入</textarea>
                        <label class="form-label mt-2" for="exclusions">排除項目與理由</label>
                        <textarea class="form-control" id="exclusions" name="exclusions" maxlength="4000"></textarea>
                        <label class="form-label mt-2" for="assumptions">假設</label>
                        <textarea class="form-control" id="assumptions" name="assumptions" maxlength="4000"></textarea>
                        <label class="form-label mt-2" for="estimationReason">估算／替代資料理由</label>
                        <textarea class="form-control" id="estimationReason" name="estimationReason" maxlength="4000"></textarea>
                        <h3 class="workspace-subheading mt-4">適用 PCR</h3>
                        <div class="workspace-select-field">
                            <label class="form-label mt-2" for="pcrVersionId">PCR 版本</label>
                            <select class="form-select" id="pcrVersionId" name="pcrVersionId" required disabled="@(!hasSelectablePcrVersions)" aria-describedby="pcrVersionId-help">
                                <option value="">@(hasSelectablePcrVersions ? "請選擇已發布 PCR 版本" : "尚無已發布 PCR 版本")</option>
                                @foreach (var pcr in Model.SelectablePcrVersions)
                                {
                                    <option value="@pcr.Id">@pcr.RegistrationNumber v@(pcr.VersionNumber) - @pcr.Title</option>
                                }
                            </select>
                            <p class="workspace-select-help" id="pcrVersionId-help">
                                @if (!hasSelectablePcrVersions)
                                {
                                    <span>草稿或已撤回版本不可使用。請先到 <a asp-page="/Workspace" asp-route-section="pcr">PCR 規範</a> 完成審查並發布。</span>
                                }
                                else
                                {
                                    <span>只列出目前已發布的 PCR 版本；期間有效性會在儲存時再次檢查。</span>
                                }
                            </p>
                        </div>
                        <button class="btn btn-primary mt-3" type="submit" disabled="@(!canCreateInventory)">儲存盤查第 1 版</button>
                    </form>
                    <h3 class="workspace-subheading mt-4">階段適用性與專案狀態</h3>
                    <p class="workspace-help">各階段資料與計算完成後，請至「計算與結果」頁統一提交整份盤查。</p>
                    <ul class="workspace-records">
                        @foreach (var inventory in Model.InventoryProjects)
                        {
                            var workflowStatus = Enum.Parse<InventoryWorkflowStatus>(inventory.WorkflowStatus);
                            <li class="mb-3">
                                @inventory.FunctionalUnit／@inventory.PcrVersion／@workflowStatus
                                @if (InventoryWorkflow.AllowsEditing(workflowStatus))
                                {
                                    @foreach (var declaration in Model.StageDeclarations.Where(item => item.InventoryProjectVersionId == inventory.Id))
                                    {
                                        <form class="mt-1 border rounded p-2" method="post" asp-page-handler="SetStageApplicability">
                                            <input type="hidden" name="stageDeclarationId" value="@declaration.Id" />
                                            <label class="form-check-label" for="stage-applicable-@declaration.Id">@((LifecycleStage)declaration.LifecycleStage) 適用</label>
                                            <input class="form-check-input" id="stage-applicable-@declaration.Id" name="isApplicable" type="checkbox" value="true" checked="@declaration.IsApplicable" />
                                            <label class="form-label" for="stage-reason-@declaration.Id">不適用原因</label>
                                            <input class="form-control" id="stage-reason-@declaration.Id" name="reason" value="@declaration.Reason" maxlength="2000" />
                                            <button class="btn btn-sm btn-outline-secondary mt-1" type="submit">更新階段</button>
                                        </form>
                                    }
                                }
                                else if (workflowStatus == InventoryWorkflowStatus.Submitted)
                                {
                                    <form class="mt-1" method="post" asp-page-handler="ReviewInventory">
                                        <input type="hidden" name="inventoryProjectVersionId" value="@inventory.Id" />
                                        <label class="form-label" for="review-comment-@inventory.Id">審查意見</label>
                                        <input class="form-control" id="review-comment-@inventory.Id" name="reviewComment" maxlength="2000" />
                                        <button class="btn btn-sm btn-success mt-1" name="decision" value="Approved" type="submit">核准</button>
                                        <button class="btn btn-sm btn-outline-warning mt-1" name="decision" value="ChangesRequested" type="submit">要求補正</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>
                }
                </div>
            </section>
        </div>
        }

        @if (Model.Section == "factors")
        {
        <div class="col-12">
            <section class="card h-100 workspace-card" id="factors">
                <div class="card-body">
                    <div class="workspace-card-heading">
                        <span class="workspace-step">05</span>
                        <div>
                            <h2 class="h4">排放係數版本</h2>
                            <p>保存係數值、單位、資料集來源、授權與適用性，供活動數據明確引用。</p>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="CreateFactor">
                        <h3 class="workspace-subheading">係數值與分母單位</h3>
                        <label class="form-label" for="factorName">係數名稱</label>
                        <input class="form-control" id="factorName" name="factorName" required />
                        <label class="form-label mt-2" for="factorValue">係數值</label>
                        <input class="form-control" type="number" step="any" min="0" id="factorValue" name="factorValue" required />
                        <label class="form-label mt-2" for="denominatorUnitCode">分母單位</label>
                        <select class="form-select" id="denominatorUnitCode" name="denominatorUnitCode">
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit.Code">kgCO2e / @unit.Code</option>
                            }
                        </select>
                        <h3 class="workspace-subheading mt-4">來源、授權與適用性</h3>
                        <label class="form-label mt-2" for="sourceDatasetVersion">來源 dataset 版本</label>
                        <input class="form-control" id="sourceDatasetVersion" name="sourceDatasetVersion" value="golden-dataset-1" required />
                        <label class="form-label mt-2" for="licenseCode">授權識別</label>
                        <input class="form-control" id="licenseCode" name="licenseCode" value="test-fixture" required />
                        <label class="form-label mt-2" for="factorSourceName">來源機構／文件</label>
                        <input class="form-control" id="factorSourceName" name="factorSourceName" required />
                        <label class="form-label mt-2" for="datasetName">資料集名稱</label>
                        <input class="form-control" id="datasetName" name="datasetName" required />
                        <label class="form-label mt-2" for="factorApplicability">適用性</label>
                        <textarea class="form-control" id="factorApplicability" name="factorApplicability" required></textarea>
                        <button class="btn btn-primary mt-3" type="submit">建立係數草稿</button>
                    </form>
                    <h3 class="workspace-subheading mt-4">審查、發布與取代版本</h3>
                    <ul class="workspace-records">
                        @foreach (var factor in Model.Factors)
                        {
                            <li class="mb-2">
                                @factor.Name：@factor.Value kgCO2e/@factor.DenominatorUnitCode（@factor.PublicationStatus）
                                @if (factor.PublicationStatus == FactorPublicationStatus.Draft.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="ReviewFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit">核准審查</button>
                                    </form>
                                    <form class="d-inline" method="post" asp-page-handler="PublishFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <button class="btn btn-sm btn-success" type="submit">發布</button>
                                    </form>
                                }
                                else if (factor.PublicationStatus == FactorPublicationStatus.Published.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="WithdrawFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">撤回</button>
                                    </form>
                                    <form class="mt-1" method="post" asp-page-handler="SupersedeFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <label class="form-label" for="new-factor-value-@factor.Id">取代版本數值</label>
                                        <input class="form-control" id="new-factor-value-@factor.Id" name="newFactorValue" type="number" step="any" min="0" required />
                                        <label class="form-label" for="new-factor-source-@factor.Id">新來源版本</label>
                                        <input class="form-control" id="new-factor-source-@factor.Id" name="newSourceDatasetVersion" required />
                                        <button class="btn btn-sm btn-outline-secondary mt-1" type="submit">建立取代草稿</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>
        }

        @if (Model.Section == "lifecycle")
        {
        <div class="col-12">
            <section class="card h-100 workspace-card" id="lifecycle">
                <div class="card-body">
                    <div class="workspace-card-heading">
                        <span class="workspace-step">06</span>
                        <div>
                            <h2 class="h4">五階段活動數據</h2>
                            <p>依舊版盤查表的階段脈絡，逐筆記錄活動量、換算單位、係數與資料品質。</p>
                        </div>
                    </div>
                    @if (Model.InventoryProjects.Count > 0)
                    {
                    <form class="lifecycle-project-selector" method="get" asp-page="/Workspace" asp-route-section="lifecycle">
                        <label class="form-label" for="projectVersionId">目前盤查版本</label>
                        <select class="form-select" id="projectVersionId" name="projectVersionId" data-auto-submit-select aria-describedby="projectVersionId-help">
                            @foreach (var inventory in Model.InventoryProjects)
                            {
                                <option value="@inventory.Id" selected="@(inventory.Id == Model.ProjectVersionId)">@inventory.FunctionalUnit / @inventory.PeriodStart～@inventory.PeriodEnd</option>
                            }
                        </select>
                        <p class="workspace-select-help" id="projectVersionId-help">變更選項後會自動切換；也可使用下方按鈕。</p>
                        <button class="btn btn-outline-primary mt-2" type="submit">切換盤查版本</button>
                    </form>
                    <nav class="lifecycle-section-nav" aria-label="五階段資料區塊">
                        @foreach (var stageSection in lifecycleSections)
                        {
                            <a href="#@stageSection.Slug"><span>@stageSection.Number</span>@stageSection.Title</a>
                        }
                    </nav>

                    <div class="lifecycle-input-list">
                        @foreach (var stageSection in lifecycleSections)
                        {
                            var stageActivities = Model.Activities.Where(item => item.InventoryProjectVersionId == Model.ProjectVersionId && item.LifecycleStage == (int)stageSection.Stage).ToArray();
                            <section class="lifecycle-input-section" id="@stageSection.Slug">
                                <header>
                                    <span>@stageSection.Number</span>
                                    <div>
                                        <h3>@stageSection.Title</h3>
                                        <p>@stageSection.Summary</p>
                                    </div>
                                    <strong>@stageActivities.Length 筆</strong>
                                </header>
                                <form method="post" asp-page-handler="AddActivity" asp-route-section="lifecycle" asp-route-projectVersionId="@Model.ProjectVersionId">
                                    <input type="hidden" name="lifecycleStage" value="@stageSection.Stage" />
                                    <input type="hidden" name="inventoryProjectVersionId" value="@Model.ProjectVersionId" />
                                    <div class="lifecycle-form-grid">
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="kind-@stageSection.Slug">活動類型</label>
                                            <select class="form-select" id="kind-@stageSection.Slug" name="activityKind" required>
                                                @foreach (var kind in stageSection.Kinds)
                                                {
                                                    <option value="@kind">@(kind switch
                                                    {
                                                        ActivityDataKind.Material => "原物料投入",
                                                        ActivityDataKind.MaterialTransport => "原物料運輸",
                                                        ActivityDataKind.Energy => "能資源使用",
                                                        ActivityDataKind.ManufacturingWaste => "製造廢棄物",
                                                        ActivityDataKind.OutsourcedTreatmentTransport => "委外處理運輸",
                                                        ActivityDataKind.DistributionTransport => "配送銷售運輸",
                                                        ActivityDataKind.UseEnergy => "使用能源",
                                                        ActivityDataKind.UseConsumable => "使用耗材",
                                                        ActivityDataKind.EndOfLifeTreatment => "廢棄處理",
                                                        ActivityDataKind.EndOfLifeTransport => "廢棄處理運輸",
                                                        _ => kind.ToString()
                                                    })</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="activity-@stageSection.Slug">@stageSection.ActivityLabel</label>
                                            <input class="form-control" id="activity-@stageSection.Slug" name="activityName" required maxlength="300" />
                                        </div>
                                        <div class="lifecycle-field lifecycle-field--wide">
                                            <label class="form-label" for="scenario-@stageSection.Slug">@stageSection.ScenarioLabel</label>
                                            <input class="form-control" id="scenario-@stageSection.Slug" name="supplierOrScenario" maxlength="1000" />
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="value-@stageSection.Slug">@stageSection.ValueLabel</label>
                                            <input class="form-control" type="number" step="any" min="0" id="value-@stageSection.Slug" name="rawValue" required />
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="raw-unit-@stageSection.Slug">原始單位</label>
                                            <select class="form-select" id="raw-unit-@stageSection.Slug" name="rawUnitCode" required>
                                                @foreach (var unit in Model.Units)
                                                {
                                                    <option value="@unit.Code">@unit.Code</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="canonical-unit-@stageSection.Slug">計算標準單位</label>
                                            <select class="form-select" id="canonical-unit-@stageSection.Slug" name="canonicalUnitCode" required>
                                                @foreach (var unit in Model.Units)
                                                {
                                                    <option value="@unit.Code">@unit.Code</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="lifecycle-field lifecycle-field--wide">
                                            <label class="form-label" for="factor-@stageSection.Slug">排放係數版本</label>
                                            <select class="form-select" id="factor-@stageSection.Slug" name="factorVersionId" required disabled="@(!hasSelectableFactors)" aria-describedby="factor-@stageSection.Slug-help">
                                                <option value="">@(hasSelectableFactors ? "請選擇已發布排放係數" : "尚無已發布排放係數")</option>
                                                @foreach (var factor in Model.SelectableFactors)
                                                {
                                                    <option value="@factor.Id">@factor.Name / kgCO2e／@factor.DenominatorUnitCode / @factor.SourceDatasetVersion</option>
                                                }
                                            </select>
                                            <p class="workspace-select-help" id="factor-@stageSection.Slug-help">
                                                @if (!hasSelectableFactors)
                                                {
                                                    <span>請先到 <a asp-page="/Workspace" asp-route-section="factors">排放係數</a> 建立、審查並發布係數版本。</span>
                                                }
                                                else
                                                {
                                                    <span>只列出已發布係數；有效期間與單位會在儲存時再次檢查。</span>
                                                }
                                            </p>
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="allocation-@stageSection.Slug">分配比例（0～1）</label>
                                            <input class="form-control" id="allocation-@stageSection.Slug" name="allocationFactor" type="number" min="0.000000000000001" max="1" step="any" value="1" required />
                                        </div>
                                        <div class="lifecycle-field">
                                            <label class="form-label" for="quality-@stageSection.Slug">資料品質</label>
                                            <select class="form-select" id="quality-@stageSection.Slug" name="dataQuality" required>
                                                <option value="primary">一級數據</option>
                                                <option value="secondary-reviewed">經審查二級數據</option>
                                                <option value="estimated">估算數據</option>
                                            </select>
                                        </div>
                                        <div class="lifecycle-field lifecycle-field--wide">
                                            <div class="form-check">
                                                <input class="form-check-input" id="estimated-@stageSection.Slug" name="isEstimated" type="checkbox" value="true" />
                                                <label class="form-check-label" for="estimated-@stageSection.Slug">此筆為估算或替代資料</label>
                                            </div>
                                            <label class="form-label mt-2" for="reason-@stageSection.Slug">估算／替代資料理由</label>
                                            <textarea class="form-control" id="reason-@stageSection.Slug" name="activityEstimationReason" maxlength="4000"></textarea>
                                        </div>
                                    </div>
                                    <button class="btn btn-primary mt-3" type="submit" disabled="@(!hasSelectableFactors)">儲存「@stageSection.Title」活動</button>
                                </form>

                                <div class="lifecycle-saved-data">
                                    <h4>已儲存的@stageSection.Title資料</h4>
                                    @if (stageActivities.Length == 0)
                                    {
                                        <p class="workspace-empty">尚未儲存此階段活動。</p>
                                    }
                                    else
                                    {
                                        <ul class="workspace-records">
                                            @foreach (var activity in stageActivities)
                                            {
                                                var evidence = Model.EvidenceFiles.SingleOrDefault(item => item.ActivityDataId == activity.Id);
                                                <li>
                                                    <strong>@activity.Name</strong>
                                                    <span>@activity.ActivityKind／@activity.CanonicalValue @activity.CanonicalUnitCode／分配 @activity.AllocationFactor</span>
                                                    @if (evidence is null)
                                                    {
                                                        <form method="post" enctype="multipart/form-data" asp-page-handler="UploadEvidence" asp-route-section="lifecycle" asp-route-projectVersionId="@Model.ProjectVersionId">
                                                            <input type="hidden" name="activityDataId" value="@activity.Id" />
                                                            <label class="form-label" for="evidence-@activity.Id">佐證檔案</label>
                                                            <input class="form-control" type="file" id="evidence-@activity.Id" name="evidenceFile" required />
                                                            <button class="btn btn-sm btn-outline-primary mt-1" type="submit">掃描並上傳</button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span>佐證：@evidence.OriginalFileName／@evidence.ScanStatus／<code>@evidence.Sha256</code></span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                    }
                    else
                    {
                        <p class="workspace-empty">尚未建立盤查版本，請先完成 02–04 的分頁設定。</p>
                    }
                </div>
            </section>
        </div>
        }
    </div>

    @if (Model.Section == "calculation")
    {
    <section class="card my-4 workspace-card workspace-calculation" id="calculation">
        <div class="card-body">
            <div class="workspace-card-heading">
                <span class="workspace-step">07</span>
                <div>
                    <h2 class="h4">凍結盤查輸入並建立計算 Run</h2>
                    <p>五個階段各至少需要一筆活動數據，且 canonical 單位須符合所選係數分母。</p>
                </div>
            </div>
            @if (Model.InventoryProjects.Count > 0)
            {
            <form class="lifecycle-project-selector" method="get" asp-page="/Workspace" asp-route-section="calculation">
            <label class="form-label" for="calculationProjectVersionId">目前盤查版本</label>
            <select class="form-select" id="calculationProjectVersionId" name="projectVersionId" data-auto-submit-select aria-describedby="calculationProjectVersionId-help">
                @foreach (var inventory in Model.InventoryProjects)
                {
                    <option value="@inventory.Id" selected="@(inventory.Id == Model.ProjectVersionId)">@inventory.FunctionalUnit / @inventory.PeriodStart～@inventory.PeriodEnd</option>
                }
            </select>
            <p class="workspace-select-help" id="calculationProjectVersionId-help">變更選項後會自動切換；也可使用下方按鈕。</p>
            <button class="btn btn-outline-primary mt-2" type="submit">切換盤查版本</button>
        </form>
            <form method="post" asp-page-handler="Calculate" asp-route-projectVersionId="@Model.ProjectVersionId">
                <input type="hidden" name="inventoryProjectVersionId" value="@Model.ProjectVersionId" />
                <button class="btn btn-success mt-3" type="submit">凍結輸入並計算</button>
            </form>
            }
            else
            {
                <p class="workspace-empty">尚未建立盤查版本，請先完成 02–04 的分頁設定。</p>
            }
        </div>
    </section>

    @if (latestSelectedRun is not null)
    {
        var run = latestSelectedRun;
        <section class="card my-4 workspace-card" id="latest-result">
            <div class="card-body">
                <div class="workspace-card-heading">
                    <span class="workspace-step workspace-step--result">結果</span>
                    <div>
                        <h2 class="h4">最新計算結果與稽核資訊</h2>
                        <p>核對輸入雜湊、引擎版本、產品總量、警告與逐項計算明細。</p>
                    </div>
                </div>
                <dl class="row">
                    <dt class="col-sm-3">Run ID</dt><dd class="col-sm-9"><code>@run.Id</code></dd>
                    <dt class="col-sm-3">Input SHA-256</dt><dd class="col-sm-9"><code>@run.InputSha256</code></dd>
                    <dt class="col-sm-3">產品總量</dt><dd class="col-sm-9">@run.ProductTotal kgCO2e</dd>
                    <dt class="col-sm-3">Engine／Rules／Units</dt><dd class="col-sm-9">@run.EngineBuild / @run.RuleSetVersion / @run.UnitCatalogueVersion</dd>
                    <dt class="col-sm-3">快照完整性</dt>
                    <dd class="col-sm-9">@(Model.LatestManifestHashValid == true ? "SHA-256 驗證通過" : "SHA-256 驗證失敗")</dd>
                </dl>
                @if (Model.LatestWarnings.Count > 0)
                {
                    <h3 class="h5">警告與假設</h3>
                    <ul>
                        @foreach (var warning in Model.LatestWarnings)
                        {
                            <li><code>@warning.Code</code>：@warning.Message</li>
                        }
                    </ul>
                }
                @if (Model.LatestDifference is { } difference)
                {
                    <h3 class="h5">與前次 Run 比較</h3>
                    <p>產品總量差異：@difference.ProductDelta kgCO2e</p>
                    <ul>
                        @foreach (var stage in difference.Stages)
                        {
                            <li>@stage.Stage：@stage.Baseline → @stage.Candidate（差異 @stage.Delta）</li>
                        }
                    </ul>
                }
                <div class="table-responsive">
                    <table class="table">
                        <thead><tr><th>階段</th><th>活動量</th><th>係數</th><th>排放量</th></tr></thead>
                        <tbody>
                        @foreach (var line in Model.LatestLines)
                        {
                            <tr>
                                <td>@((LifecycleStage)line.LifecycleStage)</td>
                                <td>@line.CanonicalActivityValue @line.ActivityUnitCode</td>
                                <td>@line.FactorValue @line.FactorUnit</td>
                                <td>@line.Emissions @line.EmissionsUnitCode</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <p class="alert alert-warning">此結果為系統內部盤查計算，不代表已查驗、ISO 認證或取得碳標籤。</p>
            </div>
        </section>
    }
    <section class="card my-4 workspace-card workspace-final-submit" id="final-submit">
        <div class="card-body">
            <div class="workspace-card-heading">
                <span class="workspace-step workspace-step--submit">提交</span>
                <div>
                    <h2 class="h4">統一提交整份盤查</h2>
                    <p>各區塊可反覆獨立儲存；確認五階段資料與不可變計算 Run 完成後，再一次提交送審。</p>
                </div>
            </div>
            <ul class="workspace-records">
                @if (Model.InventoryProjects.Count == 0)
                {
                    <li class="workspace-empty">尚未建立盤查版本，請先完成 02–04 基本資料設定。</li>
                }
                else
                {
                    @foreach (var inventory in Model.InventoryProjects)
                    {
                        var workflowStatus = Enum.Parse<InventoryWorkflowStatus>(inventory.WorkflowStatus);
                        var savedStageCount = Model.Activities
                            .Where(item => item.InventoryProjectVersionId == inventory.Id)
                            .Select(item => item.LifecycleStage)
                            .Distinct()
                            .Count();
                        var hasRun = Model.Runs.Any(item => item.ProjectVersionId == inventory.Id);
                        var hasCurrentRun = Model.CurrentRunProjectIds.Contains(inventory.Id);
                        <li class="workspace-submit-item">
                            <div>
                                <strong>@inventory.FunctionalUnit／@inventory.PeriodStart～@inventory.PeriodEnd</strong>
                                <span>已保存 @savedStageCount／5 階段｜計算 Run：@(hasCurrentRun ? "目前有效" : hasRun ? "資料已變更，請重算" : "尚未建立")｜狀態：@workflowStatus</span>
                            </div>
                            @if (InventoryWorkflow.AllowsEditing(workflowStatus))
                            {
                                <form method="post" asp-page-handler="SubmitInventory" asp-route-section="calculation">
                                    <input type="hidden" name="inventoryProjectVersionId" value="@inventory.Id" />
                                    <button class="btn btn-warning" type="submit" disabled="@(!hasCurrentRun)">統一提交盤查</button>
                                </form>
                            }
                            else
                            {
                                <span class="workspace-status-badge">@workflowStatus</span>
                            }
                        </li>
                    }
                }
            </ul>
        </div>
    </section>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
