@page
@model CarbonFootprint.Web.Pages.WorkspaceModel
@using CarbonFootprint.Domain.Modules.Factors
@using CarbonFootprint.Domain.Modules.Inventories
@using CarbonFootprint.Domain.Modules.Standards
@{
    ViewData["Title"] = "盤查工作區";
}
<h1>盤查工作區</h1>
<p class="text-muted">Golden Vertical Slice：所有資料均為開發測試資料，不代表 PCR、係數或結果已獲領域核准、查驗或主管機關核定。</p>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status">@Model.StatusMessage</div>
}
<div asp-validation-summary="All" class="text-danger" role="alert"></div>

@if (!Model.OrganizationId.HasValue)
{
    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h4">1. 建立組織</h2>
            <form method="post" asp-page-handler="CreateOrganization">
                <label class="form-label" for="organizationName">組織名稱</label>
                <input class="form-control" id="organizationName" name="organizationName" required maxlength="200" />
                <button class="btn btn-primary mt-3" type="submit">建立組織</button>
            </form>
        </div>
    </section>
}
else
{
    <p>目前組織：<code>@Model.OrganizationId</code></p>

    <div class="row g-4">
        <div class="col-lg-6">
            <section class="card h-100">
                <div class="card-body">
                    <h2 class="h4">2. 產品版本</h2>
                    <form method="post" asp-page-handler="CreateProduct">
                        <label class="form-label" for="productName">產品名稱</label>
                        <input class="form-control" id="productName" name="productName" required maxlength="300" />
                        <button class="btn btn-primary mt-3" type="submit">建立產品第 1 版</button>
                    </form>
                    <ul class="mt-3">
                        @foreach (var item in Model.ProductVersions)
                        {
                            <li>@item.NameZhTw（v@item.VersionNumber）</li>
                        }
                    </ul>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="card h-100">
                <div class="card-body">
                    <h2 class="h4">3. PCR 版本</h2>
                    <form method="post" asp-page-handler="CreatePcr">
                        <label class="form-label" for="registrationNumber">登錄編號</label>
                        <input class="form-control" id="registrationNumber" name="registrationNumber" required />
                        <label class="form-label mt-2" for="pcrTitle">名稱</label>
                        <input class="form-control" id="pcrTitle" name="title" required />
                        <label class="form-label mt-2" for="pcrVersionNumber">版本</label>
                        <input class="form-control" type="number" min="1" id="pcrVersionNumber" name="versionNumber" value="1" required />
                        <label class="form-label mt-2" for="pcrValidFrom">有效起日</label>
                        <input class="form-control" type="date" id="pcrValidFrom" name="validFrom" value="2025-01-01" />
                        <label class="form-label mt-2" for="pcrValidTo">有效迄日</label>
                        <input class="form-control" type="date" id="pcrValidTo" name="validTo" value="2027-12-31" />
                        <label class="form-label mt-2" for="sourceReference">來源參照</label>
                        <input class="form-control" id="sourceReference" name="sourceReference" placeholder="文件編號或受控來源 URI" required />
                        <button class="btn btn-primary mt-3" type="submit">建立 PCR 草稿</button>
                    </form>
                    <ul class="mt-3">
                        @foreach (var pcr in Model.PcrVersions)
                        {
                            <li class="mb-2">
                                @pcr.RegistrationNumber v@pcr.VersionNumber：@pcr.Title（@pcr.PublicationStatus）
                                @if (pcr.PublicationStatus == PcrPublicationStatus.Draft.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="PublishPcr">
                                        <input type="hidden" name="pcrVersionId" value="@pcr.Id" />
                                        <button class="btn btn-sm btn-success" type="submit">發布</button>
                                    </form>
                                }
                                else if (pcr.PublicationStatus == PcrPublicationStatus.Published.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="WithdrawPcr">
                                        <input type="hidden" name="pcrVersionId" value="@pcr.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">撤回</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="card h-100">
                <div class="card-body">
                    <h2 class="h4">4. 盤查專案版本</h2>
                    <form method="post" asp-page-handler="CreateInventory">
                        <label class="form-label" for="productVersionId">產品版本</label>
                        <select class="form-select" id="productVersionId" name="productVersionId" required>
                            @foreach (var item in Model.ProductVersions)
                            {
                                <option value="@item.Id">@item.NameZhTw v@item.VersionNumber</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="periodStart">期間起日</label>
                        <input class="form-control" type="date" id="periodStart" name="periodStart" value="2026-01-01" required />
                        <label class="form-label mt-2" for="periodEnd">期間迄日</label>
                        <input class="form-control" type="date" id="periodEnd" name="periodEnd" value="2026-12-31" required />
                        <label class="form-label mt-2" for="functionalUnit">功能單位</label>
                        <input class="form-control" id="functionalUnit" name="functionalUnit" value="1 個產品" required />
                        <label class="form-label mt-2" for="pcrVersionId">PCR 版本</label>
                        <select class="form-select" id="pcrVersionId" name="pcrVersionId" required>
                            @foreach (var pcr in Model.PcrVersions)
                            {
                                <option value="@pcr.Id">@pcr.RegistrationNumber v@pcr.VersionNumber - @pcr.Title</option>
                            }
                        </select>
                        <button class="btn btn-primary mt-3" type="submit">建立盤查第 1 版</button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="card h-100">
                <div class="card-body">
                    <h2 class="h4">5. 係數版本</h2>
                    <form method="post" asp-page-handler="CreateFactor">
                        <label class="form-label" for="factorName">係數名稱</label>
                        <input class="form-control" id="factorName" name="factorName" required />
                        <label class="form-label mt-2" for="factorValue">係數值</label>
                        <input class="form-control" type="number" step="any" min="0" id="factorValue" name="factorValue" required />
                        <label class="form-label mt-2" for="denominatorUnitCode">分母單位</label>
                        <select class="form-select" id="denominatorUnitCode" name="denominatorUnitCode">
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit.Code">kgCO2e / @unit.Code</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="sourceDatasetVersion">來源 dataset 版本</label>
                        <input class="form-control" id="sourceDatasetVersion" name="sourceDatasetVersion" value="golden-dataset-1" required />
                        <label class="form-label mt-2" for="licenseCode">授權識別</label>
                        <input class="form-control" id="licenseCode" name="licenseCode" value="test-fixture" required />
                        <button class="btn btn-primary mt-3" type="submit">建立係數草稿</button>
                    </form>
                    <ul class="mt-3">
                        @foreach (var factor in Model.Factors)
                        {
                            <li class="mb-2">
                                @factor.Name：@factor.Value kgCO2e/@factor.DenominatorUnitCode（@factor.PublicationStatus）
                                @if (factor.PublicationStatus == FactorPublicationStatus.Draft.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="PublishFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <button class="btn btn-sm btn-success" type="submit">發布</button>
                                    </form>
                                }
                                else if (factor.PublicationStatus == FactorPublicationStatus.Published.ToString())
                                {
                                    <form class="d-inline" method="post" asp-page-handler="WithdrawFactor">
                                        <input type="hidden" name="factorVersionId" value="@factor.Id" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">撤回</button>
                                    </form>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="card h-100">
                <div class="card-body">
                    <h2 class="h4">6. 五階段活動數據</h2>
                    <form method="post" asp-page-handler="AddActivity">
                        <label class="form-label" for="inventoryProjectVersionId">盤查版本</label>
                        <select class="form-select" id="inventoryProjectVersionId" name="inventoryProjectVersionId" required>
                            @foreach (var item in Model.InventoryProjects)
                            {
                                <option value="@item.Id">@item.FunctionalUnit / @item.PeriodStart～@item.PeriodEnd</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="lifecycleStage">生命週期階段</label>
                        <select class="form-select" id="lifecycleStage" name="lifecycleStage">
                            @foreach (var stage in Enum.GetValues<LifecycleStage>())
                            {
                                <option value="@stage">@stage</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="activityName">活動名稱</label>
                        <input class="form-control" id="activityName" name="activityName" required />
                        <label class="form-label mt-2" for="rawValue">原始活動量</label>
                        <input class="form-control" type="number" step="any" min="0" id="rawValue" name="rawValue" required />
                        <label class="form-label mt-2" for="rawUnitCode">原始單位</label>
                        <select class="form-select" id="rawUnitCode" name="rawUnitCode">
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit.Code">@unit.Code</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="canonicalUnitCode">Canonical 單位</label>
                        <select class="form-select" id="canonicalUnitCode" name="canonicalUnitCode">
                            @foreach (var unit in Model.Units)
                            {
                                <option value="@unit.Code">@unit.Code</option>
                            }
                        </select>
                        <label class="form-label mt-2" for="factorVersionId">係數版本</label>
                        <select class="form-select" id="factorVersionId" name="factorVersionId">
                            @foreach (var factor in Model.Factors)
                            {
                                <option value="@factor.Id">@factor.Name / @factor.DenominatorUnitCode</option>
                            }
                        </select>
                        <button class="btn btn-primary mt-3" type="submit">保存活動數據</button>
                    </form>
                    <ul class="mt-3">
                        @foreach (var activity in Model.Activities)
                        {
                            var evidence = Model.EvidenceFiles.SingleOrDefault(item => item.ActivityDataId == activity.Id);
                            <li class="mb-3">
                                @activity.Name（@((LifecycleStage)activity.LifecycleStage)，@activity.CanonicalValue @activity.CanonicalUnitCode）
                                @if (evidence is null)
                                {
                                    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadEvidence">
                                        <input type="hidden" name="activityDataId" value="@activity.Id" />
                                        <label class="form-label" for="evidence-@activity.Id">Evidence 檔案</label>
                                        <input class="form-control" type="file" id="evidence-@activity.Id" name="evidenceFile" required />
                                        <button class="btn btn-sm btn-outline-primary mt-1" type="submit">掃描並上傳</button>
                                    </form>
                                }
                                else
                                {
                                    <span>Evidence：@evidence.OriginalFileName／@evidence.ScanStatus／<code>@evidence.Sha256</code></span>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </section>
        </div>
    </div>

    <section class="card my-4">
        <div class="card-body">
            <h2 class="h4">7. 建立不可變計算 Run</h2>
            <p>五個階段各至少需要一筆活動數據，且 canonical 單位須符合所選係數分母。</p>
            <form method="post" asp-page-handler="Calculate">
                <label class="form-label" for="calculationInventoryId">盤查版本</label>
                <select class="form-select" id="calculationInventoryId" name="inventoryProjectVersionId" required>
                    @foreach (var item in Model.InventoryProjects)
                    {
                        <option value="@item.Id">@item.FunctionalUnit / @item.PcrVersion</option>
                    }
                </select>
                <button class="btn btn-success mt-3" type="submit">凍結輸入並計算</button>
            </form>
        </div>
    </section>

    @if (Model.Runs.Count > 0)
    {
        var run = Model.Runs[0];
        <section class="card my-4">
            <div class="card-body">
                <h2 class="h4">最新計算結果</h2>
                <dl class="row">
                    <dt class="col-sm-3">Run ID</dt><dd class="col-sm-9"><code>@run.Id</code></dd>
                    <dt class="col-sm-3">Input SHA-256</dt><dd class="col-sm-9"><code>@run.InputSha256</code></dd>
                    <dt class="col-sm-3">產品總量</dt><dd class="col-sm-9">@run.ProductTotal kgCO2e</dd>
                    <dt class="col-sm-3">Engine／Rules／Units</dt><dd class="col-sm-9">@run.EngineBuild / @run.RuleSetVersion / @run.UnitCatalogueVersion</dd>
                    <dt class="col-sm-3">快照完整性</dt>
                    <dd class="col-sm-9">@(Model.LatestManifestHashValid == true ? "SHA-256 驗證通過" : "SHA-256 驗證失敗")</dd>
                </dl>
                @if (Model.LatestWarnings.Count > 0)
                {
                    <h3 class="h5">警告與假設</h3>
                    <ul>
                        @foreach (var warning in Model.LatestWarnings)
                        {
                            <li><code>@warning.Code</code>：@warning.Message</li>
                        }
                    </ul>
                }
                @if (Model.LatestDifference is { } difference)
                {
                    <h3 class="h5">與前次 Run 比較</h3>
                    <p>產品總量差異：@difference.ProductDelta kgCO2e</p>
                    <ul>
                        @foreach (var stage in difference.Stages)
                        {
                            <li>@stage.Stage：@stage.Baseline → @stage.Candidate（差異 @stage.Delta）</li>
                        }
                    </ul>
                }
                <div class="table-responsive">
                    <table class="table">
                        <thead><tr><th>階段</th><th>活動量</th><th>係數</th><th>排放量</th></tr></thead>
                        <tbody>
                        @foreach (var line in Model.LatestLines)
                        {
                            <tr>
                                <td>@((LifecycleStage)line.LifecycleStage)</td>
                                <td>@line.CanonicalActivityValue @line.ActivityUnitCode</td>
                                <td>@line.FactorValue @line.FactorUnit</td>
                                <td>@line.Emissions @line.EmissionsUnitCode</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <p class="alert alert-warning">此結果為系統內部盤查計算，不代表已查驗、ISO 認證或取得碳標籤。</p>
            </div>
        </section>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
