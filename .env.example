# 建議直接執行 scripts/setup-local.ps1 或 scripts/setup-local.sh 自動產生密碼。
# 若要手動設定，請複製為 .env，並填入兩組不同的密碼。
# 密碼建議至少 16 字元；為避免 .env 與連線字串解析問題，使用英文字母、數字、句點、底線或連字號。

ASPNETCORE_ENVIRONMENT=Development
POSTGRES_DB=carbon_footprint
POSTGRES_USER=carbon_app
POSTGRES_PASSWORD=
MINIO_ROOT_USER=carbon_minio
MINIO_ROOT_PASSWORD=
OBJECTSTORAGE__ENDPOINT=http://minio:9000
OBJECTSTORAGE__BUCKET=carbon-evidence
MAIL__HOST=mailpit
MAIL__PORT=1025
